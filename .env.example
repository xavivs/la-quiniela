# Supabase (required)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Personal Access Token (Account → Access Tokens) to run:
#   npm run supabase:set-auth-urls
# Never commit real tokens. Prefer setting SUPABASE_ACCESS_TOKEN only in your shell.
# SUPABASE_ACCESS_TOKEN=sbp_your_token_here

# Optional: for fetching real match results from an external football API
# FOOTBALL_API_KEY=your-api-key
